{% comment %}
  Odanda Gör — Shopify Entegrasyonu

  Kullanım:
  1. Bu dosyayı Shopify tema snippets klasörüne ekle
  2. product.liquid veya product template'inde istediğin yere ekle:
     {% render 'odanda-gor', product: product %}

  3. VISUALIZER_URL'yi kendi deploy URL'inle değiştir
{% endcomment %}

{% assign VISUALIZER_URL = "https://odanda-gor.siteniz.com" %}

{% comment %} Sadece halı/kilim kategorisindeki ürünlerde göster {% endcomment %}
{% if product.type == 'Halı' or product.type == 'Kilim' or product.tags contains 'hali' or product.tags contains 'kilim' %}

<style>
  .odanda-gor-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #1a1a2e;
    color: #fff;
    border: none;
    padding: 12px 24px;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
    margin: 12px 0;
  }
  .odanda-gor-btn:hover {
    background: #e94560;
  }
  .odanda-gor-btn svg {
    width: 20px;
    height: 20px;
  }
  .odanda-gor-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 99999;
    background: rgba(0,0,0,0.85);
  }
  .odanda-gor-modal.active {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .odanda-gor-modal iframe {
    width: 95vw;
    height: 90vh;
    border: none;
    border-radius: 12px;
  }
  .odanda-gor-close {
    position: absolute;
    top: 12px;
    right: 20px;
    background: #e94560;
    color: white;
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    font-size: 20px;
    cursor: pointer;
    z-index: 100000;
  }
</style>

<button class="odanda-gor-btn" id="odanda-gor-trigger">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1" />
  </svg>
  Odanda Gör
</button>

<div class="odanda-gor-modal" id="odanda-gor-modal">
  <button class="odanda-gor-close" id="odanda-gor-close">&times;</button>
  <iframe id="odanda-gor-iframe" loading="lazy"></iframe>
</div>

<script>
(function() {
  var btn = document.getElementById('odanda-gor-trigger');
  var modal = document.getElementById('odanda-gor-modal');
  var closeBtn = document.getElementById('odanda-gor-close');
  var iframe = document.getElementById('odanda-gor-iframe');

  var imageUrl = {{ product.featured_image | image_url: width: 1024 | json }};

  {% comment %} Boyut bilgisini variant veya metafield'dan al {% endcomment %}
  var width = {{ product.metafields.custom.hali_en | default: 200 }};
  var height = {{ product.metafields.custom.hali_boy | default: 300 }};

  var visualizerUrl = '{{ VISUALIZER_URL }}'
    + '?image=' + encodeURIComponent(imageUrl)
    + '&width=' + width
    + '&height=' + height
    + '&name=' + encodeURIComponent({{ product.title | json }});

  btn.addEventListener('click', function() {
    iframe.src = visualizerUrl;
    modal.classList.add('active');
    document.body.style.overflow = 'hidden';
  });

  closeBtn.addEventListener('click', function() {
    modal.classList.remove('active');
    iframe.src = '';
    document.body.style.overflow = '';
  });

  modal.addEventListener('click', function(e) {
    if (e.target === modal) {
      closeBtn.click();
    }
  });
})();
</script>

{% endif %}
